<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>naplon_.keyboard.cleaner</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>Keyboard Cleaner</name>
  <summary>Lock keyboard and mouse for cleaning</summary>

  <description>
    <p>
      Keyboard Cleaner helps you safely clean your keyboard and mouse by displaying a fullscreen lock screen.
    </p>
    <p>
      The application includes a configurable background image, optional blur effect, debug mode, and a shortcut-based unlock system.
    </p>
  </description>

  <developer id="xyz.naplon">
    <name>Naplon_</name>
  </developer>
  <url type="homepage">https://naplon.xyz</url>
  <url type="vcs-browser">https://github.com/naplon74/gnome-keyboard-cleaner</url>
  <url type="bugtracker">https://github.com/naplon74/gnome-keyboard-cleaner/issues</url>

  <translation type="gettext">keyboard_cleaner</translation>

  <launchable type="desktop-id">naplon_.keyboard.cleaner.desktop</launchable>

  <icon type="stock">naplon_.keyboard.cleaner</icon>

  <categories>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>keyboard</keyword>
    <keyword>mouse</keyword>
    <keyword>cleaning</keyword>
    <keyword>lock</keyword>
    <keyword>utility</keyword>
  </keywords>

  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1c71d8</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/naplon74/gnome-keyboard-cleaner/refs/heads/main/screenshot/screenshot1.png</image>
      <caption>Keyboard Cleaner lock screen</caption>
    </screenshot>

    <screenshot>
      <image>https://raw.githubusercontent.com/naplon74/gnome-keyboard-cleaner/refs/heads/main/screenshot/settings.png</image>
      <caption>Application settings</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.1.0" date="2026-06-20">
      <description>
        <p>Initial release of Keyboard Cleaner for GNOME.</p>
        <ul>
          <li>Fullscreen cleaning mode</li>
          <li>Shortcut-based unlock system</li>
          <li>Configurable background image</li>
          <li>Optional background blur effect</li>
          <li>Debug mode for testing</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
