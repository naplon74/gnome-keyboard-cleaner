{
  "id": "io.github.Naplon.CleanMe",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "clean_me",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
  {
    "name": "python3-pillow",
    "buildsystem": "simple",
    "build-options": {
      "build-args": [
        "--share=network"
      ]
    },
    "build-commands": [
      "pip3 install --prefix=/app Pillow"
    ]
  },
  {
    "name": "clean_me",
    "builddir": true,
    "buildsystem": "meson",
    "sources": [
      {
        "type": "git",
        "url": "file:///home/naplon/Projects"
      }
    ]
  }
]
}